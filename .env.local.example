# Public — safe to expose to the browser (RLS is what actually protects data)
NEXT_PUBLIC_SUPABASE_URL=https://udtydecgnqfsbwuhlxpf.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Used to build the email confirmation redirect link (registerInvestor ->
# emailRedirectTo). Must exactly match an entry in Supabase Dashboard ->
# Authentication -> URL Configuration -> Redirect URLs, or confirmation links will
# fail even if SMTP is working correctly.
# Local dev:  http://localhost:3000
# Production: https://your-real-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DEMO ONLY — Role Switcher (stakeholder presentations)
# Set to "true" for demo deploys. Must be absent or "false" in production.
# If this is "true" in production, any visitor can become Super Admin with one click.
NEXT_PUBLIC_ENABLE_DEMO_SWITCHER=false
# Only used by src/lib/supabase/server.js#createAdminClient() for operations that must
# bypass RLS (e.g. Super Admin creating a Finance Officer's auth user + temp password).
# Get this from Supabase Dashboard -> Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=
